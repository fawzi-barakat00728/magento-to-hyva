<script>
(function () {
    var modal = document.getElementById('ftc-cart-email-modal');
    if (
        !modal ||
        !document.body.classList.contains('checkout-cart-index') ||
        window.matchMedia('(max-width: 767px)').matches
    ) {
        return;
    }

    var key = 'ftc_cart_email_modal_shown';
    var isGuest = !document.body.classList.contains('customer-logged-in');

    if (!isGuest || sessionStorage.getItem(key)) {
        return;
    }

    var openModal = function () {
        modal.classList.add('is-open');
        modal.setAttribute('aria-hidden', 'false');
    };

    var closeModal = function () {
        modal.classList.remove('is-open');
        modal.setAttribute('aria-hidden', 'true');
    };

    setTimeout(function () {
        openModal();
        sessionStorage.setItem(key, '1');
    }, 350);

    var closeBtn = modal.querySelector('.ftc-cart-email-modal__close');
    var submitBtn = modal.querySelector('.ftc-cart-email-modal__submit');

    if (closeBtn) {
        closeBtn.addEventListener('click', closeModal);
    }
    if (submitBtn) {
        submitBtn.addEventListener('click', closeModal);
    }
    modal.addEventListener('click', function (event) {
        if (event.target === modal) {
            closeModal();
        }
    });
})();
</script>
