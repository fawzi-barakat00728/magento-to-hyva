    <script>
    (function () {
      const buttonSelector = '.js-ftc-load-more';
      const listContainerSelector = '.products.wrapper.products-grid, .products.wrapper.products-list';

      const bindLoadMore = () => {
        document.querySelectorAll(buttonSelector).forEach((button) => {
          if (button.dataset.loadMoreBound === '1') {
            return;
          }
          button.dataset.loadMoreBound = '1';

          button.addEventListener('click', async (event) => {
            const trigger = event.currentTarget;
            const nextUrl = trigger.getAttribute('href');
            if (!nextUrl || trigger.dataset.loading === '1') {
              return;
            }

            event.preventDefault();
            trigger.dataset.loading = '1';

            const originalLabel = trigger.textContent.trim();
            const loadingLabel = trigger.getAttribute('data-loading-label') || originalLabel;
            trigger.textContent = loadingLabel;
            trigger.classList.add('is-loading');
            trigger.setAttribute('aria-busy', 'true');

            try {
              const response = await fetch(nextUrl, {
                credentials: 'same-origin',
                headers: {'X-Requested-With': 'XMLHttpRequest'}
              });
              if (!response.ok) {
                throw new Error('Load failed: ' + response.status);
              }

              const html = await response.text();
              const parser = new DOMParser();
              const nextDocument = parser.parseFromString(html, 'text/html');

              const currentScope = trigger.closest('#amasty-shopby-product-list') || trigger.closest('.column.main') || document;
              const currentContainer = currentScope.querySelector(listContainerSelector) || document.querySelector(listContainerSelector);
              const nextContainer = nextDocument.querySelector('#amasty-shopby-product-list ' + listContainerSelector + ', ' + listContainerSelector);
              if (!currentContainer || !nextContainer) {
                throw new Error('Product container not found');
              }

              let appended = 0;
              Array.from(nextContainer.children).forEach((child) => {
                const isProductsList = child.matches && child.matches('ol.products.list.items.product-items');
                const isBanner = child.matches && child.matches('.catalog-banner-cms');
                if (isProductsList || isBanner) {
                  currentContainer.appendChild(document.importNode(child, true));
                  appended++;
                }
              });

              if (!appended) {
                throw new Error('No products appended');
              }

              const nextButton = nextDocument.querySelector(buttonSelector);
              if (nextButton && nextButton.getAttribute('href')) {
                trigger.setAttribute('href', nextButton.getAttribute('href'));
                trigger.textContent = originalLabel;
                trigger.removeAttribute('aria-busy');
                trigger.dataset.loading = '0';
                trigger.classList.remove('is-loading');
              } else {
                const toolbar = trigger.closest('.toolbar-bottom') || trigger.closest('.toolbar');
                if (toolbar) {
                  toolbar.remove();
                } else {
                  trigger.remove();
                }
              }
            } catch (error) {
              window.location.href = nextUrl;
            }
          });
        });
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', bindLoadMore, {once: true});
      } else {
        bindLoadMore();
      }
    })();
    </script>

