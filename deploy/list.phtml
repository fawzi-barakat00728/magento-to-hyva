    // Force deterministic category position order for PLP parity.
    // Some migrated categories were rendered by entity_id despite "position" sorter.
    $requestedOrder = strtolower((string) $block->getRequest()->getParam('product_list_order', ''));
    $requestedDir = strtolower((string) $block->getRequest()->getParam('product_list_dir', 'asc'));
    if ($requestedDir !== 'desc') {
      $requestedDir = 'asc';
    }
    if ($requestedOrder === '' || $requestedOrder === 'position') {
      try {
        $resourceConnection = $objectManager->get(\Magento\Framework\App\ResourceConnection::class);
        $connection = $resourceConnection->getConnection();
        $storeManager = $objectManager->get(\Magento\Store\Model\StoreManagerInterface::class);
        $storeId = (int) $storeManager->getStore()->getId();
        $categoryId = $category ? (int) $category->getId() : 0;

        if ($categoryId > 0) {
          $indexTable = 'catalog_category_product_index_store' . $storeId;
          if (!$connection->isTableExists($indexTable)) {
            $indexTable = 'catalog_category_product';
          }

          $sql = sprintf(
            'SELECT product_id FROM %s WHERE category_id = :category_id ORDER BY position %s, product_id %s',
            $indexTable,
            strtoupper($requestedDir),
            strtoupper($requestedDir)
          );
          $orderedIds = array_map('intval', $connection->fetchCol($sql, ['category_id' => $categoryId]));

          if ($orderedIds) {
            $pageSize = (int) $_productCollection->getPageSize();
            if ($pageSize <= 0) {
              $pageSize = 20;
            }
            $curPage = (int) $_productCollection->getCurPage();
            if ($curPage < 1) {
              $curPage = 1;
            }

            $sliceIds = array_slice($orderedIds, ($curPage - 1) * $pageSize, $pageSize);

            if ($sliceIds) {
              $collectionFactory = $objectManager->get(\Magento\Catalog\Model\ResourceModel\Product\CollectionFactory::class);
              $visibility = $objectManager->get(\Magento\Catalog\Model\Product\Visibility::class);

              $forcedCollection = $collectionFactory->create();
              $forcedCollection->setStoreId($storeId);
              $forcedCollection->addStoreFilter($storeId);
              $forcedCollection->addAttributeToSelect('*');
              $forcedCollection->addIdFilter($sliceIds);
              $forcedCollection->setVisibility($visibility->getVisibleInCatalogIds());
              $forcedCollection->getSelect()->reset(\Zend_Db_Select::ORDER);
              $forcedCollection->getSelect()->order(
                new \Zend_Db_Expr('FIELD(e.entity_id,' . implode(',', array_map('intval', $sliceIds)) . ')')
              );
              $forcedCollection->load();

              $_productCollection = $forcedCollection;
            }
          }
        }
      } catch (\Throwable $e) {
        if ($_productCollection->isLoaded()) {
          $_productCollection->clear();
        }
        $_productCollection->setOrder('position', strtoupper($requestedDir));
      }
    }


    function countWithoutVideos($images) {
      $count = 0;
      foreach ($images as $image) {
        if (!isVideoImage($image)) {
          $count++;
        }
      }
      return $count;
    }

    function isVideoImage($image) {
      return $image->getData()["video_url"] !== null;
    }

