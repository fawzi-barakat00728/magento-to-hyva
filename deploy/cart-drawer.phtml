            <div class="ftc-cart-modal-extra" x-html="getSectionDataExtraActions"></div>
            <?= $block->getChildHtml('extra_actions'); ?>
            <?= $block->getChildHtml('cart-drawer.bottom'); ?>
        </div>
    </template>

    <?= $block->getChildHtml('loading') ?>
</dialog>
