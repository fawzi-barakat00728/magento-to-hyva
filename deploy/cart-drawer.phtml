                    <span class="ftc-cart-modal-subtotal price-box" x-html="cart.subtotal"></span>
                </div>
                <button
                    type="button"
                    class="ftc-cart-modal-close"
                    @click="closeCartDrawer"
                    aria-label="<?= $escaper->escapeHtmlAttr(__('Close minicart')) ?>"
                >
                    <?= $lucideIcons->xHtml('', 24, 24, ['aria-hidden' => 'true']); ?>
                </button>
            </div>

            <?= $block->getChildHtml('cart-drawer.items.before'); ?>

            <ul class="ftc-cart-modal-items-list">
                <template x-for="item in cartItems">
                    <li class="ftc-cart-modal-item">
                        <template x-if="productIsVisibleInSite(item)">
                            <a
