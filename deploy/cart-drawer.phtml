                        </div>
                    </li>
                </template>
            </ul>

            <?= $block->getChildHtml('cart-drawer.totals.before'); ?>

            <div class="ftc-cart-modal-actions">
                <a
                    href="<?= $escaper->escapeUrl($block->getUrl('checkout/cart')) ?>"
