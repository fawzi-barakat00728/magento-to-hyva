                            >
                                <img
                                    class="ftc-cart-modal-item-image"
                                    :src="item.product_image.src"
                                    :width="item.product_image.width"
                                    :height="item.product_image.height"
                                    loading="lazy"
                                    :alt="item.product_name"
                                >
                            </a>
                        </template>
                        <template x-if="productIsNotVisibleInSite(item)">
                            <div class="ftc-cart-modal-item-image-link">
                                <img
                                    class="ftc-cart-modal-item-image"
                                    :src="item.product_image.src"
                                    :width="item.product_image.width"
                                    :height="item.product_image.height"
                                    loading="lazy"
                                    :alt="item.product_name"
                                />
                            </div>
                        </template>

                        <div class="ftc-cart-modal-item-content">
                            <div class="ftc-cart-modal-item-main">
