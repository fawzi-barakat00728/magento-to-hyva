<?php
/**
 * Custom Mega Menu for FTC Cashmere Hyva Theme
 * Replaces default Hyva desktop.phtml with multi-level navigation
 * matching original FTC site structure
 */

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\HyvaCsp;
use Hyva\Theme\ViewModel\Navigation;
use Magento\Framework\View\Element\Template;
use Magento\Framework\Escaper;

/** @var Template $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */
/** @var HyvaCsp $hyvaCsp */

/** @var Navigation $viewModelNavigation */
$viewModelNavigation = $viewModels->require(Navigation::class, $block);

// Get 4 levels deep
$menuItems = $viewModelNavigation->getNavigation(4);
$block->setData('cache_tags', $viewModelNavigation->getIdentities());
?>

<div x-data="initMegaMenu" class="z-20 navigation hidden lg:flex">
    <div class="hidden lg:block w-full">
        <nav
            class="relative mega-nav"
            aria-label="<?= $escaper->escapeHtmlAttr(__('Main menu')) ?>"
        >
            <ul class="mega-nav-level0 flex justify-start flex-wrap">
                <?php foreach ($menuItems as $index => $menuItem): ?>
                    <li
                        class="mega-nav-item level-0"
                        x-data="{ open: false }"
                        @mouseenter="open = true"
                        @mouseleave="open = false"
                        @keydown.escape="open = false"
                    >
                        <a
                            href="<?= $escaper->escapeUrl($menuItem['url']) ?>"
                            class="mega-nav-link level-0"
                        >
                            <span><?= $escaper->escapeHtml($menuItem['name']) ?></span>
                        </a>

                        <?php if (!empty($menuItem['childData'])): ?>
                            <!-- Level 1 dropdown panel -->
                            <div
                                class="mega-dropdown"
                                x-show="open"
                                x-transition:enter="transition ease-out duration-200"
                                x-transition:enter-start="opacity-0"
                                x-transition:enter-end="opacity-100"
                                x-transition:leave="transition ease-in duration-150"
                                x-transition:leave-start="opacity-100"
                                x-transition:leave-end="opacity-0"
                                x-cloak
                            >
                                <div class="mega-dropdown-inner">
                                    <!-- Level 1 tabs (e.g., Featured, Ready to wear) -->
                                    <ul class="mega-level1-list">
                                        <?php foreach ($menuItem['childData'] as $subIndex => $subMenuItem): ?>
                                            <li
                                                class="mega-level1-item<?= !empty($subMenuItem['childData']) ? ' has-children' : ' no-children' ?>"
                                                x-data="{ subOpen: false }"
                                                @mouseenter="subOpen = true"
                                                @mouseleave="subOpen = false"
                                            >
                                                <a
                                                    href="<?= $escaper->escapeUrl($subMenuItem['url']) ?>"
                                                    class="mega-level1-link"
                                                >
                                                    <span><?= $escaper->escapeHtml($subMenuItem['name']) ?></span>
                                                </a>

                                                <?php if (!empty($subMenuItem['childData'])): ?>
                                                    <!-- Level 2 sub-panel -->
                                                    <div
                                                        class="mega-level2-panel"
                                                        x-show="subOpen"
                                                        x-transition:enter="transition ease-out duration-150"
                                                        x-transition:enter-start="opacity-0"
                                                        x-transition:enter-end="opacity-100"
                                                        x-transition:leave="transition ease-in duration-100"
                                                        x-transition:leave-start="opacity-100"
                                                        x-transition:leave-end="opacity-0"
                                                        x-cloak
                                                    >
                                                        <div class="mega-level2-columns">
                                                            <?php foreach ($subMenuItem['childData'] as $level2Item): ?>
                                                                <div class="mega-level2-column">
                                                                    <a
                                                                        href="<?= $escaper->escapeUrl($level2Item['url']) ?>"
                                                                        class="mega-level2-link"
                                                                    >
                                                                        <span><?= $escaper->escapeHtml($level2Item['name']) ?></span>
                                                                    </a>

                                                                    <?php if (!empty($level2Item['childData'])): ?>
                                                                        <!-- Level 3 items -->
                                                                        <ul class="mega-level3-list">
                                                                            <?php foreach ($level2Item['childData'] as $level3Item): ?>
                                                                                <li>
                                                                                    <a
                                                                                        href="<?= $escaper->escapeUrl($level3Item['url']) ?>"
                                                                                        class="mega-level3-link"
                                                                                    >
                                                                                        <span><?= $escaper->escapeHtml($level3Item['name']) ?></span>
                                                                                    </a>
                                                                                </li>
                                                                            <?php endforeach; ?>
                                                                        </ul>
                                                                    <?php endif; ?>
                                                                </div>
                                                            <?php endforeach; ?>
                                                        </div>
                                                    </div>
                                                <?php endif; ?>
                                            </li>
                                        <?php endforeach; ?>
                                    </ul>
                                </div>
                            </div>
                        <?php endif; ?>
                    </li>
                <?php endforeach; ?>
            </ul>
        </nav>
    </div>
</div>

<script>
    function initMegaMenu() {
        return {
            init() {
                this.setActiveMenu();
            },
            setActiveMenu() {
                Array.from(this.$root.querySelectorAll('a')).forEach(link => {
                    if (link.href === `${window.location.origin}${window.location.pathname}`) {
                        link.setAttribute('aria-current', 'page');
                    }
                });
            }
        }
    }

    window.addEventListener('alpine:init', () => {
        Alpine.data('initMegaMenu', initMegaMenu);
    }, { once: true })
</script>
<?php $hyvaCsp->registerInlineScript() ?>
