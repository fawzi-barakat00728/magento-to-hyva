<script>
    function ftcHeader() {
        return {
            mobileMenuOpen: false,
            openSub: null,
            showBanner: true,
            showRegionChooser: false,
            selectedCountry: null,
            selectedLang: '<?= $escaper->escapeJs(strtolower(explode('_', $locale)[0])) ?>',

            init() {
                // Check if banner was dismissed
                if (localStorage.getItem('ftc_banner_dismissed')) {
                    this.showBanner = false;
                }
            },

            dismissBanner() {
                this.showBanner = false;
                localStorage.setItem('ftc_banner_dismissed', '1');
            },

            selectCountry(code) {
                this.selectedCountry = code;
            },

            applyRegion() {
                if (!this.selectedCountry) return;

                // Build store code from country + language
                const storeCode = this.selectedLang + '-' + this.selectedCountry;
                const urlInput = document.querySelector(
                    `input[name="store_url_${storeCode}"]`
                );

                if (urlInput && urlInput.value) {
                    window.location.href = urlInput.value;
                } else {
                    // Fallback: try just the language variant
                    const fallback = document.querySelector(
                        `input[name^="store_url_${this.selectedLang}-"]`
                    );
                    if (fallback && fallback.value) {
                        window.location.href = fallback.value;
                    }
                }
            }
        };
    }
</script>
