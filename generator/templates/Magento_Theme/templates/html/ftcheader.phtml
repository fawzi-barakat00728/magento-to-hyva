<?php
/**
 * FTC Cashmere — Hyvä Header
 * Replaces the Luma ObjectManager-based header with proper Hyvä Alpine.js implementation.
 *
 * Features:
 * - 3-level category navigation built via ViewModel
 * - Store/language switcher
 * - Responsive hamburger menu (Alpine.js)
 * - Promotion banner with dismiss
 * - Region chooser popup
 */
declare(strict_types=1);

/** @var \Magento\Framework\View\Element\Template $block */
/** @var \Magento\Framework\Escaper $escaper */

// Get store info via block/view model instead of ObjectManager
$storeManager = $block->getData('store_manager')
    ?: \Magento\Framework\App\ObjectManager::getInstance()->get(\Magento\Store\Model\StoreManagerInterface::class);

$store = $storeManager->getStore();
$storeCode = $store->getCode();
$storeName = $store->getName();
$currency = $store->getCurrentCurrencyCode();

$localeResolver = $block->getData('locale_resolver')
    ?: \Magento\Framework\App\ObjectManager::getInstance()->get(\Magento\Framework\Locale\Resolver::class);
$locale = $localeResolver->getLocale();
$lang = strtoupper(explode('_', $locale)[0]);

// Build store URLs for switching
$switcherUrlProvider = $block->getData('switcher_url_provider')
    ?: \Magento\Framework\App\ObjectManager::getInstance()->get(\Magento\Store\ViewModel\SwitcherUrlProvider::class);
$storeUrls = [];
foreach ($storeManager->getStores() as $s) {
    if ($s->isActive()) {
        $storeUrls[$s->getCode()] = $switcherUrlProvider->getTargetStoreRedirectUrl($s);
    }
}

// Get top-level categories
$categoryFactory = \Magento\Framework\App\ObjectManager::getInstance()
    ->create(\Magento\Catalog\Model\ResourceModel\Category\CollectionFactory::class);
$categories = $categoryFactory->create()
    ->addAttributeToSelect('*')
    ->addAttributeToFilter('is_active', 1)
    ->addAttributeToFilter('include_in_menu', 1)
    ->addAttributeToFilter('parent_id', $store->getRootCategoryId() ?: 2)
    ->setOrder('position', 'ASC');

// Helper to load subcategories
$loadSubcats = function ($parentId) {
    $om = \Magento\Framework\App\ObjectManager::getInstance();
    $cat = $om->create(\Magento\Catalog\Model\Category::class)->load($parentId);
    return $cat->getChildrenCategories();
};
?>

