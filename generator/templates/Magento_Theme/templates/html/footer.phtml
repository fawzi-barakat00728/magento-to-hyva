<?php
/**
 * FTC Cashmere — Hyvä Footer
 * Replaces the Luma jQuery-based footer with Alpine.js.
 *
 * Features:
 * - CMS block for footer content (footer_areas)
 * - Newsletter subscription (Alpine.js)
 * - Social icons
 * - Mobile accordion sections
 * - Back-to-top button
 * - Popup system for CMS popups
 */
declare(strict_types=1);

/** @var \Magento\Framework\View\Element\Template $block */
/** @var \Magento\Framework\Escaper $escaper */
?>

<footer class="page-footer">
    <div class="area links">
        <?= /** @noEscape */
        $block->getLayout()
            ->createBlock(\Magento\Cms\Block\Block::class)
            ->setBlockId('footer_areas')
            ->toHtml() ?>
    </div>

    <!-- Newsletter -->
    <div class="area" x-data="ftcNewsletter()">
        <div class="block newsletter">
            <form class="form subscribe"
                  @submit.prevent="subscribe()"
                  novalidate>
                <div style="display: flex; align-items: flex-end;">
                    <div class="field newsletter" style="flex: 1; margin-right: 5%;">
                        <label for="newsletter-footer" class="sr-only">
                            <?= $escaper->escapeHtml(__('Email address')) ?>
                        </label>
                        <input type="email"
                               name="email"
                               id="newsletter-footer"
                               x-model="email"
                               :placeholder="'<?= $escaper->escapeJs(__('E-Mail Address')) ?>'"
                               required
                               style="padding: 20px 0; border: none; border-bottom: 1px solid #eee; background: transparent; font-size: 15px; width: 100%;">
                    </div>
                    <div class="actions" style="width: 25%;">
                        <button type="submit"
                                :disabled="loading"
                                style="opacity: 0.8; width: 100%; padding: 12px 0; border: none; border-radius: 0; background: transparent; font-size: 14px; color: var(--color-primary, #ad8b70); text-transform: uppercase; border-bottom: 2px solid var(--color-primary, #ad8b70); cursor: pointer; transition: opacity 0.3s;"
                                @mouseenter="$el.style.opacity = '1'"
                                @mouseleave="$el.style.opacity = '0.8'">
                            <span x-text="loading ? '<?= $escaper->escapeJs(__('Subscribing...')) ?>' : '<?= $escaper->escapeJs(__('Subscribe')) ?>'"></span>
                        </button>
                    </div>
                </div>
                <template x-if="message">
                    <div class="mt-2 text-sm" :class="success ? 'text-green-600' : 'text-red-600'"
                         x-text="message"></div>
                </template>
            </form>
        </div>
    </div>

    <div class="area bottom" style="border-top: 1px solid #e0e0e0; padding-top: 25px;">
        <div class="legal">
            &copy; <?= date('Y') ?> FTC Cashmere
        </div>
        <div class="social">
            <a href="https://www.instagram.com/ftccashmere/" target="_blank" rel="noopener"
               class="icon instagram"
               style="background-image: url('<?= $escaper->escapeUrl($block->getViewFileUrl('images/social/instagram.png')) ?>');"
               aria-label="Instagram"></a>
            <a href="https://www.facebook.com/ftccashmere" target="_blank" rel="noopener"
               class="icon facebook"
               style="background-image: url('<?= $escaper->escapeUrl($block->getViewFileUrl('images/social/facebook.png')) ?>');"
               aria-label="Facebook"></a>
            <a href="https://www.pinterest.com/ftccashmere/" target="_blank" rel="noopener"
               class="icon pinterest"
               style="background-image: url('<?= $escaper->escapeUrl($block->getViewFileUrl('images/social/pinterest.png')) ?>');"
               aria-label="Pinterest"></a>
            <a href="https://www.youtube.com/ftccashmere" target="_blank" rel="noopener"
               class="icon youtube"
               style="background-image: url('<?= $escaper->escapeUrl($block->getViewFileUrl('images/social/youtube.png')) ?>');"
               aria-label="YouTube"></a>
        </div>
    </div>
</footer>

<!-- Popup system for CMS popups -->
<div class="hidden popups" x-data="{ open: false }" x-show="open" x-cloak>
    <div class="ftc-overlay" @click.self="open = false">
        <div class="ftc-popup">
            <div class="ftc-close" @click="open = false">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </div>
            <?= /** @noEscape */
            $block->getLayout()
                ->createBlock(\Magento\Cms\Block\Block::class)
                ->setBlockId('popups')
                ->toHtml() ?>
        </div>
    </div>
</div>

<!-- Back to top -->
<div x-data="backToTop()"
     class="back-to-top"
     :class="{ 'visible': show }"
     @click="scrollToTop()"
     aria-label="<?= $escaper->escapeHtmlAttr(__('Back to top')) ?>">
</div>

<script>
    function ftcNewsletter() {
        return {
            email: '',
            loading: false,
            message: '',
            success: false,

            async subscribe() {
                if (!this.email) return;
                this.loading = true;
                this.message = '';

                try {
                    const formData = new FormData();
                    formData.append('email', this.email);

                    const response = await fetch(
                        '<?= $escaper->escapeJs($block->getUrl("newsletter/subscriber/new")) ?>',
                        {
                            method: 'POST',
                            body: formData,
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest'
                            }
                        }
                    );

                    if (response.ok) {
                        this.success = true;
                        this.message = '<?= $escaper->escapeJs(__('Thank you for your subscription.')) ?>';
                        this.email = '';
                    } else {
                        this.success = false;
                        this.message = '<?= $escaper->escapeJs(__('Something went wrong with the subscription.')) ?>';
                    }
                } catch (e) {
                    this.success = false;
                    this.message = '<?= $escaper->escapeJs(__('Something went wrong with the subscription.')) ?>';
                }

                this.loading = false;
            }
        };
    }

    function backToTop() {
        return {
            show: false,

            init() {
                window.addEventListener('scroll', () => {
                    this.show = window.scrollY > 400;
                });
            },

            scrollToTop() {
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        };
    }

    // Footer accordion on mobile
    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('.page-footer .section h3').forEach(h3 => {
            h3.addEventListener('click', () => {
                if (window.innerWidth <= 768) {
                    h3.closest('.section').classList.toggle('open');
                }
            });
        });

        // FTC popup system
        document.querySelectorAll('.ftc-popup-button').forEach(btn => {
            btn.addEventListener('click', () => {
                const overlay = btn.parentElement.querySelector('.ftc-overlay')
                    || btn.closest('.block').querySelector('.ftc-overlay');
                if (overlay) overlay.style.display = 'block';
            });
        });
    });
</script>
