/**
 * Hyvä Child Theme — Footer
 * Auto-generated by magento-to-hyva migration tool.
 *
 * Renders the footer CMS block content (footer_areas or similar)
 * with Alpine.js newsletter subscription and mobile accordion.
 * Social icons and legal text come from the CMS block itself.
 */
declare(strict_types=1);

/** @var \Magento\Framework\View\Element\Template $block */
/** @var \Magento\Framework\Escaper $escaper */

// Try common footer CMS block identifiers used by Luma themes.
// Most themes use one of these for their footer content.
$footerBlockIds = ['footer_areas', 'footer_links', 'footer', 'footer-content'];
$footerHtml = '';
foreach ($footerBlockIds as $blockId) {
    $footerHtml = $block->getLayout()
        ->createBlock(\Magento\Cms\Block\Block::class)
        ->setBlockId($blockId)
        ->toHtml();
    if (trim($footerHtml)) {
        break;
    }
}
?>

<footer class="page-footer">
    <?php if ($footerHtml): ?>
        <div class="area links">
            <?= /** @noEscape */ $footerHtml ?>
        </div>
    <?php endif; ?>

    <!-- Newsletter subscription (Alpine.js) -->
    <div class="area" x-data="ftcNewsletter()">
        <div class="block newsletter">
            <form class="form subscribe"
                  @submit.prevent="subscribe()"
                  novalidate>
                <div style="display: flex; align-items: flex-end;">
                    <div class="field newsletter" style="flex: 1; margin-right: 5%;">
                        <label for="newsletter-footer" class="sr-only">
                            <?= $escaper->escapeHtml(__('Email address')) ?>
                        </label>
                        <input type="email"
                               name="email"
                               id="newsletter-footer"
                               x-model="email"
                               :placeholder="'<?= $escaper->escapeJs(__('E-Mail Address')) ?>'"
                               required
                               style="padding: 20px 0; border: none; border-bottom: 1px solid #eee; background: transparent; font-size: 15px; width: 100%;">
                    </div>
                    <div class="actions" style="width: 25%;">
                        <button type="submit"
                                :disabled="loading"
                                style="opacity: 0.8; width: 100%; padding: 12px 0; border: none; border-radius: 0; background: transparent; font-size: 14px; color: var(--color-primary, #ad8b70); text-transform: uppercase; border-bottom: 2px solid var(--color-primary, #ad8b70); cursor: pointer; transition: opacity 0.3s;"
                                @mouseenter="$el.style.opacity = '1'"
                                @mouseleave="$el.style.opacity = '0.8'">
                            <span x-text="loading ? '<?= $escaper->escapeJs(__('Subscribing...')) ?>' : '<?= $escaper->escapeJs(__('Subscribe')) ?>'"></span>
                        </button>
                    </div>
                </div>
                <template x-if="message">
                    <div class="mt-2 text-sm" :class="success ? 'text-green-600' : 'text-red-600'"
                         x-text="message"></div>
                </template>
            </form>
        </div>
    </div>

    <!-- Copyright -->
    <div class="area bottom" style="border-top: 1px solid #e0e0e0; padding-top: 25px;">
        <div class="legal">
            <?= /* @noEscape */ $block->getCopyright() ?>
        </div>
    </div>
</footer>

<!-- Back to top -->
<div x-data="backToTop()"
     class="back-to-top"
     :class="{ 'visible': show }"
     @click="scrollToTop()"
     aria-label="<?= $escaper->escapeHtmlAttr(__('Back to top')) ?>">
</div>

<script>
    function ftcNewsletter() {
        return {
            email: '',
            loading: false,
            message: '',
            success: false,

            async subscribe() {
                if (!this.email) return;
                this.loading = true;
                this.message = '';

                try {
                    const formData = new FormData();
                    formData.append('email', this.email);

                    const response = await fetch(
                        '<?= $escaper->escapeJs($block->getUrl("newsletter/subscriber/new")) ?>',
                        {
                            method: 'POST',
                            body: formData,
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest'
                            }
                        }
                    );

                    if (response.ok) {
                        this.success = true;
                        this.message = '<?= $escaper->escapeJs(__('Thank you for your subscription.')) ?>';
                        this.email = '';
                    } else {
                        this.success = false;
                        this.message = '<?= $escaper->escapeJs(__('Something went wrong with the subscription.')) ?>';
                    }
                } catch (e) {
                    this.success = false;
                    this.message = '<?= $escaper->escapeJs(__('Something went wrong with the subscription.')) ?>';
                }

                this.loading = false;
            }
        };
    }

    function backToTop() {
        return {
            show: false,

            init() {
                window.addEventListener('scroll', () => {
                    this.show = window.scrollY > 400;
                });
            },

            scrollToTop() {
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        };
    }

    // Footer accordion on mobile
    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('.page-footer .section h3').forEach(h3 => {
            h3.addEventListener('click', () => {
                if (window.innerWidth <= 768) {
                    h3.closest('.section').classList.toggle('open');
                }
            });
        });
    });
</script>
